NODE_ENV=development
PORT=8000

# Local Docker Postgres (docker-compose.yml uses port 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/custom_websites_db

# Production frontend URL (required in production for CORS)
FRONTEND_URL=http://localhost:5173

# Optional extra allowed origins, comma-separated
# CORS_ORIGINS=https://www.example.com,https://staging.example.com

# Gmail app password for confirmation emails (optional locally)
EMAIL_ADDRESS=liviyalawrence30@gmail.com
EMAIL_PASSWORD=gwcf evyq rvui vbxp

# Database migrations (run automatically on npm start / npm run dev)
# npm run migrate          — apply pending migrations
# npm run migrate:baseline — one-time: mark migrations applied if tables already exist
# npm run migrate:down     — rollback last migration
# npm run migrate:create   — create a new migration file
